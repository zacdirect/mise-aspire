#!/usr/bin/env bash

set -euo pipefail

current_script_path=${BASH_SOURCE[0]}
plugin_dir=$(dirname "$(dirname "$current_script_path")")

# shellcheck source=./lib/utils.bash
source "${plugin_dir}/lib/utils.bash"

# Emit 'daily' first, then any locally installed pinned builds sorted newest-first.
# We do not pipe through sort_versions because 'daily' is not a semver token
# and the ordering produced by list_all_versions is already meaningful.
list_all_versions | xargs echo
